# =============================================================================
# IMMUNICARE BACKEND DEVELOPMENT ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.development for local development.

NODE_ENV=development
PORT=5000
HTTPS_PORT=5443
ENABLE_HTTPS=false

# Database Configuration (Local Development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=immunicare_dev
DB_USER=immunicare_dev
DB_PASSWORD=replace-with-local-dev-db-password
DB_SSL=false

# JWT Configuration (use strong random values even in dev)
JWT_SECRET=replace-with-random-dev-jwt-secret-min-32
JWT_REFRESH_SECRET=replace-with-random-dev-refresh-secret-min-32
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_CLOCK_TOLERANCE_SECONDS=5

# Authentication and security
PASSWORD_MIN_LENGTH=8
PASSWORD_HISTORY_SIZE=10
SESSION_TIMEOUT=15
ABSOLUTE_SESSION_TIMEOUT=480
MAX_CONCURRENT_SESSIONS=5

RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX_LOGIN=5
RATE_LIMIT_MAX_FORGOT_PASSWORD=3
AUTH_RATE_LIMIT_MAX=200

BRUTE_FORCE_MAX_ATTEMPTS=3
BRUTE_FORCE_LOCKOUT_DURATION=900000

# CORS and frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Cache / Redis
CACHE_DISABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# CSRF (dev only)
CSRF_DISABLED=true

# SSL paths (used only if ENABLE_HTTPS=true)
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.crt

# Email
MAILERSEND_API_KEY=
RESEND_API_KEY=
RESEND_EMAIL_FROM=Immunicare <onboarding@resend.dev>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM_EMAIL=noreply@immunicare.local
MAIL_FROM_NAME=Immunicare
EMAIL_DISABLED=false

# SMS
SMS_GATEWAY=log
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=
TEXTBEE_SENDER_NAME=IMMUNICARE
SMS_REMINDERS_ENABLED=true
TEST_PHONE_NUMBER=
