# =============================================================================
# IMMUNICARE BACKEND TEST ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.test and use isolated, disposable test resources only.

NODE_ENV=test

# Database - isolated test DB only
DB_HOST=localhost
DB_PORT=5432
DB_NAME=immunicare_test
DB_USER=postgres
DB_PASSWORD=replace-with-test-db-password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Allow unsafe test DB override for local test execution only
IMMUNICARE_ALLOW_UNSAFE_TEST_DB=true

# JWT secrets for tests (still use random values)
JWT_SECRET=replace-with-test-jwt-secret-min-32
JWT_REFRESH_SECRET=replace-with-test-refresh-secret-min-32
JWT_ACCESS_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# Test stability flags
CACHE_DISABLED=true
CSRF_DISABLED=true
SECURITY_DB_ENABLED=false
LOG_LEVEL=error
DB_SUPPRESS_POOL_LOGS=true

# App ports for local test runtime
PORT=5000
HTTPS_PORT=5443
ENABLE_HTTPS=false

# Rate limits relaxed for test suites
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX_LOGIN=100
RATE_LIMIT_MAX_FORGOT_PASSWORD=100

# Brute-force controls relaxed for tests
BRUTE_FORCE_MAX_ATTEMPTS=100
BRUTE_FORCE_LOCKOUT_DURATION=60000

# SMS in test mode
SMS_GATEWAY=log
