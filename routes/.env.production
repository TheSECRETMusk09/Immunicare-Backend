# Production Environment Variables for Immunicare Frontend
#
# This file is loaded during the `npm run build` process.
# Ensure these values point to your live, deployed backend API.

# The base URL for the backend API.
REACT_APP_API_URL=https://api.immunicareph.site

# The URL for the WebSocket server, typically the same as the API URL.
REACT_APP_SOCKET_URL=https://api.immunicareph.site

# The path for the Socket.IO connection.
REACT_APP_SOCKET_PATH=/socket.io
