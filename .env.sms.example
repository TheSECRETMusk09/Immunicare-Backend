# Example SMS provider configuration for the backend.
# Copy the relevant values into `.env.production` or `.env.hostinger`.

# Common
SMS_MAX_PER_HOUR=20
SMS_MAX_PER_DAY=100
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60

# TextBee
SMS_GATEWAY=textbee
TEXTBEE_API_KEY=replace_with_textbee_api_key
TEXTBEE_DEVICE_ID=replace_with_textbee_device_id
TEXTBEE_SENDER_NAME=IMMUNICARE

# Twilio
# SMS_GATEWAY=twilio
# TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
# TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
# TWILIO_PHONE_NUMBER=replace_with_twilio_number

# Semaphore
# SMS_GATEWAY=semaphore
# SEMAPHORE_API_KEY=replace_with_semaphore_api_key
