# SMS Gateway Configuration
# Copy this file to .env and configure your SMS provider

# ============================================================================
# SMS Gateway Selection
# Options: log, semaphore, twilio, aws-sns, textbee
# ============================================================================
SMS_GATEWAY=textbee

# ============================================================================
# TextBee SMS Gateway (Philippines/Southeast Asia)
# Sign up at: https://textbee.dev/
# ============================================================================
TEXTBEE_API_KEY=your_textbee_api_key_here
TEXTBEE_DEVICE_ID=your_textbee_device_id
TEXTBEE_SENDER_NAME=IMMUNICARE

# ============================================================================
# Semaphore SMS Gateway (Philippines)
# Sign up at: https://semaphore.co/
# ============================================================================
SEMAPHORE_API_KEY=your_semaphore_api_key_here
SEMAPHORE_SENDER_NAME=Immunicare

# ============================================================================
# Twilio SMS Gateway (International)
# Sign up at: https://twilio.com/
# ============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# AWS SNS Configuration
# Sign up at: https://aws.amazon.com/sns/
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
AWS_SNS_SENDER_ID=Immunicare

# ============================================================================
# OTP Configuration
# ============================================================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60

# ============================================================================
# Rate Limiting
# ============================================================================
SMS_MAX_PER_HOUR=10
SMS_MAX_PER_DAY=50
