# =============================================================================
# IMMUNICARE BACKEND PRODUCTION ENVIRONMENT CONFIGURATION (EXAMPLE)
# =============================================================================
# Copy this file to `.env.production` on the VPS and replace all placeholder values.
# Start the backend with: `npm run start:prod`

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
ENABLE_HTTPS=false
HTTPS_PORT=5443

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# If PostgreSQL runs on the same VPS as the backend, use 127.0.0.1
# If PostgreSQL is remote, use the remote hostname/IP.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=immunicare_prod
DB_USER=immunicare_user
DB_PASSWORD=replace_with_real_database_password
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_QUERY_TIMEOUT=25000
DB_STATEMENT_TIMEOUT=25000
DB_ACQUIRE_TIMEOUT=15000

# =============================================================================
# JWT & AUTHENTICATION SECRETS
# =============================================================================
JWT_SECRET=replace_with_secure_64_plus_character_secret
JWT_REFRESH_SECRET=replace_with_different_secure_64_plus_character_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_CLOCK_TOLERANCE_SECONDS=5

SESSION_TIMEOUT=15
ABSOLUTE_SESSION_TIMEOUT=480
MAX_CONCURRENT_SESSIONS=3
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# =============================================================================
# FRONTEND & CORS CONFIGURATION
# =============================================================================
FRONTEND_URL=https://immunicareph.site
CORS_ORIGIN=https://immunicareph.site
CORS_CREDENTIALS=true

# =============================================================================
# CACHE / SECURITY / LOGGING
# =============================================================================
CACHE_DISABLED=true
PASSWORD_MIN_LENGTH=10
PASSWORD_HISTORY_SIZE=5
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX_LOGIN=5
RATE_LIMIT_MAX_FORGOT_PASSWORD=3
AUTH_RATE_LIMIT_MAX=10
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_DURATION=900000
CSRF_DISABLED=true
LOG_LEVEL=info
LOG_SECURITY_EVENTS=true
LOG_RETENTION_DAYS=30
ENABLE_METRICS=false

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
MAILERSEND_API_KEY=
MAIL_FROM_EMAIL=notifications@immunicareph.site
MAIL_FROM_NAME=Immunicare
EMAIL_DISABLED=false
EMAIL_MAX_PER_HOUR=50
EMAIL_MAX_PER_DAY=500

# =============================================================================
# SMS CONFIGURATION
# =============================================================================
SMS_GATEWAY=textbee
TEXTBEE_API_KEY=replace_with_textbee_api_key
TEXTBEE_DEVICE_ID=replace_with_textbee_device_id
TEXTBEE_SENDER_NAME=IMMUNICARE
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60
SMS_MAX_PER_HOUR=20
SMS_MAX_PER_DAY=100

# =============================================================================
# SCHEDULER / API
# =============================================================================
AUTO_START_VACCINATION_REMINDERS=true
VACCINATION_REMINDER_INTERVAL_MINUTES=1440
VACCINATION_REMINDER_DAYS_ADVANCE=7
API_BASE_URL=https://api.immunicareph.site
