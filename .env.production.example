# =============================================================================
# IMMUNICARE BACKEND PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.production in deployment secrets storage.
# Never commit real values.

NODE_ENV=production
PORT=5000
HTTPS_PORT=5443
ENABLE_HTTPS=false

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=immunicare_prod
DB_USER=immunicare_app
DB_PASSWORD=replace-with-strong-db-password

# Database hardening
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MIN=2
DB_POOL_MAX=30
DB_IDLE_TIMEOUT=60000
DB_CONNECTION_TIMEOUT=15000
DB_QUERY_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000
DB_ACQUIRE_TIMEOUT=30000

# Optional TLS material (base64 encoded PEM)
# DB_SSL_CA=
# DB_SSL_CERT=
# DB_SSL_KEY=

# Optional dedicated security DB
# SECURITY_DB_ENABLED=true
# SECURITY_DB_HOST=
# SECURITY_DB_PORT=5432
# SECURITY_DB_NAME=immunicare_security
# SECURITY_DB_USER=
# SECURITY_DB_PASSWORD=

# =============================================================================
# JWT & AUTHENTICATION (REQUIRED)
# =============================================================================
JWT_SECRET=replace-with-64-plus-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-64-plus-char-random-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_CLOCK_TOLERANCE_SECONDS=5

COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# =============================================================================
# CORS / FRONTEND / API ORIGINS (REQUIRED)
# =============================================================================
FRONTEND_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com
CORS_CREDENTIALS=true

# =============================================================================
# HTTPS CERTIFICATE PATHS (REQUIRED IF ENABLE_HTTPS=true)
# =============================================================================
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.crt

# =============================================================================
# REDIS / CACHE
# =============================================================================
CACHE_DISABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# AUTH / SECURITY
# =============================================================================
PASSWORD_MIN_LENGTH=10
PASSWORD_HISTORY_SIZE=10
SESSION_TIMEOUT=15
ABSOLUTE_SESSION_TIMEOUT=480
MAX_CONCURRENT_SESSIONS=5

RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX_LOGIN=5
RATE_LIMIT_MAX_FORGOT_PASSWORD=3
AUTH_RATE_LIMIT_MAX=10

BRUTE_FORCE_MAX_ATTEMPTS=3
BRUTE_FORCE_LOCKOUT_DURATION=900000

CSRF_DISABLED=false
ADMIN_IP_WHITELIST=
ADMIN_LOGIN_NOTIFICATION=true

LOG_SECURITY_EVENTS=true
LOG_RETENTION_DAYS=90
LOG_LEVEL=info

# =============================================================================
# EMAIL PROVIDER (configure at least one fully)
# =============================================================================
# Option A: MailerSend
MAILERSEND_API_KEY=replace-with-mailersend-api-key

# Option B: Resend
# RESEND_API_KEY=replace-with-resend-api-key
# RESEND_EMAIL_FROM=notifications@example.com

# Option C: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mailer-user
# SMTP_PASSWORD=replace-with-smtp-password

MAIL_FROM_EMAIL=notifications@example.com
MAIL_FROM_NAME=Immunicare
EMAIL_DISABLED=false
EMAIL_MAX_PER_HOUR=50
EMAIL_MAX_PER_DAY=500

# =============================================================================
# SMS PROVIDER
# =============================================================================
SMS_GATEWAY=textbee

# TextBee
TEXTBEE_API_KEY=replace-with-textbee-api-key
TEXTBEE_DEVICE_ID=replace-with-textbee-device-id
TEXTBEE_SENDER_NAME=IMMUNICARE

# Twilio (if SMS_GATEWAY=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Semaphore (if SMS_GATEWAY=semaphore)
# SEMAPHORE_API_KEY=
# SEMAPHORE_SENDER_NAME=Immunicare

# OTP and limits
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN=60
SMS_MAX_PER_HOUR=20
SMS_MAX_PER_DAY=100
SMS_REMINDERS_ENABLED=true

ENABLE_METRICS=true
